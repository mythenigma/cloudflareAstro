---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PerformanceMonitor from '../components/PerformanceMonitor.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	lang?: string;
	noindex?: boolean;
	/** Override nav brand (e.g. MaiImg posts use MaiImg instead of MaiPDF). */
	headerTitle?: string;
	article?: {
		pubDate: string;
		updatedDate?: string;
		tags?: string[];
	};
}

const { 
	title = SITE_TITLE, 
	description = SITE_DESCRIPTION, 
	image,
	lang = 'en', // Default to English, but allow override
	noindex = false,
	headerTitle,
	article
} = Astro.props;

const navBrand = headerTitle ?? SITE_TITLE;
---

<!DOCTYPE html>
<html lang={lang}>
		<head>
			<!-- charset MUST be the very first thing in head -->
			<meta charset="utf-8" />
			<BaseHead title={title} description={description} image={image} article={article} noindex={noindex} />
		</head>
	<body>
		<Header title={navBrand} />
		<main>
			<slot />
		</main>
		<Footer />
		<PerformanceMonitor />
	</body>
</html>
