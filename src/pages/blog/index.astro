---
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

/** Same rule as BlogPost.astro: show the more recent of publish vs update. */
function getDisplayDate(data: { pubDate: Date; updatedDate?: Date }) {
	const publishedAt = data.pubDate instanceof Date ? data.pubDate : new Date(data.pubDate);
	const updatedAt = data.updatedDate
		? data.updatedDate instanceof Date
			? data.updatedDate
			: new Date(data.updatedDate)
		: null;
	return updatedAt && updatedAt.getTime() > publishedAt.getTime() ? updatedAt : publishedAt;
}

const posts = (await getCollection('blog'))
	.filter((post) => post.data.noindex !== true)
	.sort((a, b) => getDisplayDate(b.data).valueOf() - getDisplayDate(a.data).valueOf());

const sections = {
	English: posts.filter((post) => post.id.startsWith('en/')),
	Chinese: posts.filter((post) => post.id.startsWith('cn/')),
	French: posts.filter((post) => post.id.startsWith('fr/')),
	German: posts.filter((post) => post.id.startsWith('de/')),
	Japanese: posts.filter((post) => post.id.startsWith('ja/')),
	Korean: posts.filter((post) => post.id.startsWith('ko/')),
	Spanish: posts.filter((post) => post.id.startsWith('es/')),
};

// Flag sections with content to display
const sectionsWithContent = Object.entries(sections).filter(([_, posts]) => posts.length > 0);
---

<Layout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<style>
		.blog-header {
			text-align: center;
			padding: 2rem 0;
			background: linear-gradient(to right, #4a6cf7, #2563eb);
			color: white;
			margin-bottom: 0;
			border-radius: 0 0 1rem 1rem;
		}
		
		.container {
			width: 100%;
			max-width: 1200px;
			margin: 0 auto;
			padding: 0 1rem;
		}

		/* ── Language Filter Bar ── */
		.filter-bar {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			gap: 0.5rem;
			padding: 1rem 0 1.5rem;
			position: sticky;
			top: 0;
			z-index: 10;
			background: #f9fafb;
			border-bottom: 1px solid #e5e7eb;
			margin-bottom: 1.5rem;
		}

		.lang-btn {
			padding: 0.4rem 1rem;
			border-radius: 2rem;
			border: 2px solid #d1d5db;
			background: white;
			color: #374151;
			font-size: 0.875rem;
			font-weight: 600;
			cursor: pointer;
			transition: all 0.2s;
			user-select: none;
		}
		.lang-btn:hover {
			border-color: #4a6cf7;
			color: #4a6cf7;
		}
		.lang-btn.active {
			background: #4a6cf7;
			border-color: #4a6cf7;
			color: white;
		}
		.lang-btn .count {
			font-size: 0.75rem;
			opacity: 0.7;
			margin-left: 0.25rem;
		}

		/* ── Grid adapts to visible column count ── */
		.sections-grid {
			display: grid;
			gap: 1.5rem;
			margin-bottom: 3rem;
			grid-template-columns: 1fr;            /* default: single column */
		}
		.sections-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
		.sections-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }

		.section-box {
			background: white;
			border-radius: 0.75rem;
			box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
			overflow: hidden;
			display: none;                          /* hidden until activated */
			flex-direction: column;
			transition: transform 0.3s, box-shadow 0.3s;
		}
		.section-box.visible {
			display: flex;
		}

		/* Height varies with column count */
		.sections-grid.cols-1 .section-box { max-height: none; }
		.sections-grid.cols-2 .section-box,
		.sections-grid.cols-3 .section-box { max-height: 600px; }
		
		.section-box:hover {
			transform: translateY(-3px);
			box-shadow: 0 6px 25px rgba(0, 0, 0, 0.15);
		}
		
		.section-header {
			background: linear-gradient(to right, #4a6cf7, #2563eb);
			color: white;
			padding: 0.75rem 1rem;
			font-weight: bold;
			font-size: 1.1rem;
			text-align: center;
			border-bottom: 2px solid #e5e7eb;
			flex-shrink: 0;
		}
		
		.section-content {
			flex-grow: 1;
			overflow-y: auto;
			scrollbar-width: thin;
			padding: 0.5rem;
		}
		
		.section-content::-webkit-scrollbar { width: 6px; }
		.section-content::-webkit-scrollbar-thumb {
			background-color: rgba(74, 108, 247, 0.5);
			border-radius: 3px;
		}
		.section-content::-webkit-scrollbar-track { background: #f1f1f1; }
		
		.post-item {
			padding: 1rem;
			border-bottom: 1px solid #e5e7eb;
			transition: background-color 0.2s;
		}
		
		.post-item:hover { background-color: #f9fafb; }
		.post-item:last-child { border-bottom: none; }
		
		.post-title {
			font-size: 1.125rem;
			font-weight: 600;
			color: #111827;
			margin-bottom: 0.5rem;
			display: block;
		}
		
		.post-title-offline {
			color: #667eea;
			font-weight: 700;
			position: relative;
			padding-left: 0.75rem;
		}
		
		.post-title-offline::before {
			content: '';
			position: absolute;
			left: 0;
			top: 0;
			bottom: 0;
			width: 4px;
			background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			border-radius: 2px;
		}
		
		.post-date {
			font-size: 0.75rem;
			color: #6b7280;
			margin-bottom: 0.5rem;
		}
		
		.post-description {
			font-size: 0.875rem;
			color: #4b5563;
			line-height: 1.5;
		}
		
		.empty-section {
			display: flex;
			justify-content: center;
			align-items: center;
			height: 100%;
			color: #9ca3af;
			font-style: italic;
			text-align: center;
			padding: 2rem;
		}
		
		@media (max-width: 768px) {
			.sections-grid,
			.sections-grid.cols-2,
			.sections-grid.cols-3 {
				grid-template-columns: 1fr;
			}
			.filter-bar { gap: 0.35rem; }
			.lang-btn { font-size: 0.8rem; padding: 0.35rem 0.75rem; }
		}
	</style>
	
	<div class="blog-header">
		<div class="container">
			<h1 class="text-4xl font-bold">Our Blog</h1>
			<p class="mt-2 text-xl opacity-80">Explore our latest articles and insights</p>
		</div>
	</div>
	
	<div class="container">
		<!-- Language filter buttons -->
		<div class="filter-bar" id="langFilter">
			<button class="lang-btn active" data-lang="all">All languages</button>
			{Object.entries(sections).map(([language, langPosts]) => (
				<button class="lang-btn" data-lang={language}>
					{language}<span class="count">({langPosts.length})</span>
				</button>
			))}
		</div>

		<div class="sections-grid" id="sectionsGrid">
			{Object.entries(sections).map(([language, langPosts]) => (
				<div class="section-box visible" data-section={language}>
					<div class="section-header">
						{language}
					</div>
					<div class="section-content">
						{langPosts.length > 0 ? (
							langPosts.map((post) => {
								const offlineKeywords = [
									"offline", "离线", "オフライン", "오프라인",
									"hors ligne", "sin conexión"
								];
								const isOffline =
									offlineKeywords.some(kw => post.data.title.toLowerCase().includes(kw)) ||
									(post.data.tags && post.data.tags.some((tag: string) => offlineKeywords.some(kw => tag.toLowerCase().includes(kw)))) ||
									post.id.toLowerCase().includes('offline');
								return (
									<a href={`/blog/${post.id}`} class="post-item block">
										<h3 class={`post-title${isOffline ? ' post-title-offline' : ''}`}>{post.data.title}</h3>
										<p class="post-date">
											<FormattedDate date={getDisplayDate(post.data)} />
										</p>
										<p class="post-description">{post.data.description}</p>
									</a>
								);
							})
						) : (
							<div class="empty-section">
								<p>No articles available in {language} yet.<br/>Check back soon!</p>
							</div>
						)}
					</div>
				</div>
			))}
		</div>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const filter = document.getElementById('langFilter')!;
			const grid = document.getElementById('sectionsGrid')!;
			const buttons = filter.querySelectorAll<HTMLButtonElement>('.lang-btn');
			const boxes = grid.querySelectorAll<HTMLElement>('.section-box');

			function update(selected: string) {
				// Toggle active button
				buttons.forEach(b => b.classList.toggle('active', b.dataset.lang === selected));

				// Show/hide sections
				let visibleCount = 0;
				boxes.forEach(box => {
					const show = selected === 'all' || box.dataset.section === selected;
					box.classList.toggle('visible', show);
					if (show) visibleCount++;
				});

				// Adapt grid columns
				grid.classList.remove('cols-1', 'cols-2', 'cols-3');
				if (visibleCount === 1) grid.classList.add('cols-1');
				else if (visibleCount === 2) grid.classList.add('cols-2');
				else grid.classList.add('cols-3');

				// Remember choice
				try { localStorage.setItem('blog-lang', selected); } catch {}
			}

			buttons.forEach(btn => {
				btn.addEventListener('click', () => update(btn.dataset.lang!));
			});

			// Restore saved language or default to all
			let saved = 'all';
			try { saved = localStorage.getItem('blog-lang') || 'all'; } catch {}
			update(saved);
		});
	</script>
</Layout>
