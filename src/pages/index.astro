---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const pageTitle = 'MaiPDF Secure Sharing Guides | Online Sharing and App DRM';
const pageDescription = 'A Taiji-style guide map for MaiPDF: choose fast online PDF sharing or stronger App DRM protection, then browse every related guide by theme.';

function getDisplayDate(data: { pubDate: Date; updatedDate?: Date }) {
  const publishedAt = data.pubDate instanceof Date ? data.pubDate : new Date(data.pubDate);
  const updatedAt = data.updatedDate
    ? data.updatedDate instanceof Date
      ? data.updatedDate
      : new Date(data.updatedDate)
    : null;
  return updatedAt && updatedAt.getTime() > publishedAt.getTime() ? updatedAt : publishedAt;
}

const allPosts = (await getCollection('blog'))
  .filter((post) => post.data.noindex !== true)
  .sort((a, b) => getDisplayDate(b.data).valueOf() - getDisplayDate(a.data).valueOf());

const postUrl = (post: (typeof allPosts)[number]) => `/blog/${post.id.replace(/\.mdx?$/, '')}`;

const featuredSlugs = [
  'en/online-pdf-sharing-vs-app-drm',
  'en/free-pdf-screenshot-protection-software',
  'en/secure-pdf-reader-with-screenshot-protection',
  'en/pdf-online-drm-complete-guide',
  'en/what-is-a-maipdf-file',
  'en/how-to-revoke-access-to-a-pdf-after-sending',
];

const featuredPosts = featuredSlugs
  .map((slug) => allPosts.find((post) => post.id.replace(/\.mdx?$/, '') === slug))
  .filter((post): post is (typeof allPosts)[number] => Boolean(post));

const statBlocks = [
  { value: allPosts.length.toString(), label: 'indexable guides' },
  { value: '2', label: 'sharing paths' },
  { value: '1', label: 'control model' },
];

const decisionCards = [
  {
    side: 'Yang / Online Sharing',
    title: 'A link or QR code when sharing needs to move fast',
    desc: 'Best for browser reading, public or semi-private delivery, quick client review, expiry, view limits, watermarking, and open tracking.',
    href: 'https://maipdf.com',
    cta: 'Open MaiPDF online sharing',
    tone: 'light',
  },
  {
    side: 'Yin / App DRM',
    title: 'A protected .maipdf file when control matters more',
    desc: 'Best for screenshot-aware reading, device binding, revocation, license checks, and content that should not behave like a normal attachment.',
    href: 'https://drm.maipdf.com',
    cta: 'Explore MaiPDF App DRM',
    tone: 'dark',
  },
];

type Theme = {
  id: string;
  title: string;
  eyebrow: string;
  desc: string;
  match: string[];
  posts: typeof allPosts;
};

const themeDefinitions: Omit<Theme, 'posts'>[] = [
  {
    id: 'online-sharing',
    eyebrow: 'Yang path',
    title: 'Online PDF sharing, links, hosting, QR codes',
    desc: 'Guides for turning a PDF into a controlled web link or QR code without asking readers to install an app.',
    match: ['share', 'sharing', 'host', 'hosting', 'link', 'qr', 'qrcode', 'upload', 'online viewing', 'browser', 'whatsapp', 'facebook', 'wechat'],
  },
  {
    id: 'app-drm',
    eyebrow: 'Yin path',
    title: 'App DRM, .maipdf files, screenshot protection',
    desc: 'When browser controls are not enough: protected readers, screenshot protection, device binding, licenses, and revocation.',
    match: ['drm', 'maipdf file', '.maipdf', 'screenshot', 'reader', 'device', 'binding', 'revoke', 'license', 'certificate', 'prevent file copying'],
  },
  {
    id: 'access-control',
    eyebrow: 'Rules',
    title: 'Access limits, expiry, self-destruction, revocation',
    desc: 'Practical pages for setting view counts, expiry windows, delete-after-reading behavior, and post-send access changes.',
    match: ['limit', 'expiry', 'expire', 'expiration', 'self-destruct', 'destruction', 'revoke', 'view count', 'time restriction', 'access control', 'after sending'],
  },
  {
    id: 'watermark-tracking',
    eyebrow: 'Traceability',
    title: 'Watermarking, tracking, analytics, leak deterrence',
    desc: 'Dynamic watermark and analytics content that explains how to make forwarding riskier and leaks easier to trace.',
    match: ['watermark', 'tracking', 'analytics', 'trace', 'logs', 'engagement', 'leak'],
  },
  {
    id: 'business-use-cases',
    eyebrow: 'Use cases',
    title: 'Education, enterprise, consultants, creators, healthcare',
    desc: 'Scenario guides that translate MaiPDF controls into real distribution workflows for teams and creators.',
    match: ['education', 'student', 'course', 'training', 'enterprise', 'corporate', 'consultant', 'coach', 'creator', 'healthcare', 'architectural', 'proposal', 'portfolio', 'resume', 'workbook', 'exam', 'sales', 'confidential'],
  },
  {
    id: 'comparison-security',
    eyebrow: 'Strategy',
    title: 'Security comparisons and best practices',
    desc: 'Pages that compare tools, explain trade-offs, and help readers choose the right protection level.',
    match: ['best practices', 'comparison', 'compare', 'alternative', 'securely', 'security', 'protect', 'confidential', 'safeguard', 'prevent downloads', 'view-only', 'copy'],
  },
  {
    id: 'maiimg',
    eyebrow: 'Adjacent product',
    title: 'Maiimg image sharing and gallery controls',
    desc: 'Image and gallery sharing articles that sit next to the PDF workflow for users who also need controlled image delivery.',
    match: ['maiimg', 'image', 'photo', 'gallery', 'portfolio sharing for designers'],
  },
  {
    id: 'international',
    eyebrow: 'Global library',
    title: 'Chinese, Spanish, French, Japanese and other localized guides',
    desc: 'Localized articles that target the same sharing and protection themes in additional languages.',
    match: ['cn/', 'es/', 'fr/', 'ja/', 'de/', 'it/', 'ko/'],
  },
];

function normalize(post: (typeof allPosts)[number]) {
  return `${post.id} ${post.data.title ?? ''} ${post.data.description ?? ''} ${(post.data.tags ?? []).join(' ')}`.toLowerCase();
}

const assigned = new Set<string>();
const themes: Theme[] = themeDefinitions.map((theme) => {
  const posts = allPosts.filter((post) => {
    if (assigned.has(post.id)) return false;
    const haystack = normalize(post);
    const matched = theme.match.some((keyword) => haystack.includes(keyword.toLowerCase()));
    if (matched) assigned.add(post.id);
    return matched;
  });
  return { ...theme, posts };
});

const remainingPosts = allPosts.filter((post) => !assigned.has(post.id));
if (remainingPosts.length > 0) {
  themes.push({
    id: 'full-library',
    eyebrow: 'Archive',
    title: 'More MaiPDF library pages',
    desc: 'Additional pages from the blog library that do not fit neatly into the main product themes.',
    match: [],
    posts: remainingPosts,
  });
}

const nonEmptyThemes = themes.filter((theme) => theme.posts.length > 0);
---

<Layout title={pageTitle} description={pageDescription}>
  <section class="taiji-hero" aria-labelledby="hero-title">
    <div class="hero-shell">
      <div class="hero-copy">
        <p class="eyebrow">MaiPDF Taiji control map</p>
        <h1 id="hero-title">One document. Two forces. One controlled sharing system.</h1>
        <p class="hero-text">
          The homepage now treats MaiPDF as a Taiji model: online sharing is the fast bright path,
          App DRM is the stronger dark path, and the blog library below becomes the map that connects every guide to the right use case.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="btn btn-dark" href="#guide-map">Browse guide themes</a>
          <a class="btn btn-light" href="https://maipdf.com">Online sharing</a>
          <a class="btn btn-outline" href="https://drm.maipdf.com">App DRM</a>
        </div>
        <div class="hero-stats" aria-label="MaiPDF guide index stats">
          {statBlocks.map((stat) => (
            <span><strong>{stat.value}</strong>{stat.label}</span>
          ))}
        </div>
      </div>

      <aside class="taiji-orbit" aria-label="Online sharing and App DRM balance illustration">
        <div class="taiji-mark" aria-hidden="true">
          <span class="dot dot-light"></span>
          <span class="dot dot-dark"></span>
        </div>
        <div class="orbit-label orbit-online">
          <span>Online Sharing</span>
          <strong>Link · QR · Browser</strong>
        </div>
        <div class="orbit-label orbit-drm">
          <span>App DRM</span>
          <strong>.maipdf · Device · Revoke</strong>
        </div>
      </aside>
    </div>
  </section>

  <section class="dual-section" aria-labelledby="dual-title">
    <div class="section-intro center">
      <p class="eyebrow">Choose the force first</p>
      <h2 id="dual-title">The design is not a pasted picture — the whole page uses the same black/white Taiji logic.</h2>
      <p>
        Bright side for speed and reach. Dark side for device-level control. The homepage keeps both visible so readers can choose the right path before entering the article library.
      </p>
    </div>
    <div class="decision-grid">
      {decisionCards.map((card) => (
        <article class={`decision-card ${card.tone}`}>
          <p class="card-side">{card.side}</p>
          <h3>{card.title}</h3>
          <p>{card.desc}</p>
          <a href={card.href}>{card.cta} →</a>
        </article>
      ))}
    </div>
  </section>

  <section class="featured-section" aria-labelledby="featured-title">
    <div class="section-intro">
      <p class="eyebrow">Start here</p>
      <h2 id="featured-title">Core pages that explain the two-path model</h2>
    </div>
    <div class="featured-grid">
      {featuredPosts.map((post, index) => (
        <a class="featured-card" href={postUrl(post)}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section id="guide-map" class="guide-map" aria-labelledby="guide-map-title">
    <div class="section-intro center inverted">
      <p class="eyebrow">Complete theme map</p>
      <h2 id="guide-map-title">All related blog links, grouped by the homepage theme</h2>
      <p>
        Instead of leaving the homepage as only a hero page, the article library is surfaced here by topic so readers can move from the Taiji concept into the exact guide they need.
      </p>
    </div>

    <div class="theme-stack">
      {nonEmptyThemes.map((theme) => (
        <section class="theme-panel" id={theme.id} aria-labelledby={`${theme.id}-title`}>
          <div class="theme-heading">
            <p class="eyebrow">{theme.eyebrow}</p>
            <h3 id={`${theme.id}-title`}>{theme.title}</h3>
            <p>{theme.desc}</p>
            <strong>{theme.posts.length} guides</strong>
          </div>
          <div class="theme-links">
            {theme.posts.map((post) => (
              <a href={postUrl(post)}>
                <span>{post.id.split('/')[0].toUpperCase()}</span>
                <strong>{post.data.title}</strong>
                <small>{post.data.description}</small>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>

<style>
  :global(body) {
    background: #f4f1ea;
    color: #111;
  }

  :global(main) {
    background:
      radial-gradient(circle at 8% 8%, rgba(255, 255, 255, 0.92), transparent 30rem),
      radial-gradient(circle at 92% 16%, rgba(0, 0, 0, 0.10), transparent 26rem),
      linear-gradient(180deg, #f7f3eb 0%, #e8e0d1 42%, #111 42%, #050505 100%);
  }

  .taiji-hero,
  .dual-section,
  .featured-section,
  .guide-map {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .taiji-hero {
    min-height: calc(100vh - 80px);
    display: grid;
    align-items: center;
    padding: clamp(3rem, 7vw, 7rem) 0;
  }

  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .hero-copy h1,
  .section-intro h2 {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  .hero-copy h1 {
    max-width: 760px;
    font-size: clamp(3.25rem, 8.5vw, 7.9rem);
    line-height: 0.88;
    font-weight: 850;
  }

  .eyebrow {
    margin: 0 0 1rem;
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #7c6b4f;
  }

  .hero-text,
  .section-intro p,
  .decision-card p,
  .theme-heading p {
    color: rgba(17, 17, 17, 0.76);
    font-size: 1.12rem;
    line-height: 1.72;
  }

  .hero-text {
    max-width: 700px;
    margin: 1.5rem 0 0;
    font-weight: 520;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0.86rem 1.36rem;
    border-radius: 999px;
    font-size: 0.98rem;
    font-weight: 780;
    text-decoration: none;
    transition: transform 160ms ease, background 160ms ease, color 160ms ease;
  }

  .btn:hover { transform: translateY(-2px); }
  .btn-dark { background: #111; color: #fff; }
  .btn-light { background: #fff; color: #111; box-shadow: inset 0 0 0 1px rgba(17,17,17,.1); }
  .btn-outline { color: #111; box-shadow: inset 0 0 0 1px rgba(17,17,17,.35); }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
    max-width: 560px;
    margin-top: 2.2rem;
  }

  .hero-stats span {
    padding: 1rem;
    border-radius: 22px;
    background: rgba(255,255,255,.55);
    box-shadow: inset 0 0 0 1px rgba(17,17,17,.08);
    color: rgba(17,17,17,.62);
    font-size: .82rem;
  }

  .hero-stats strong {
    display: block;
    color: #111;
    font-size: 1.8rem;
    line-height: 1;
  }

  .taiji-orbit {
    position: relative;
    min-height: min(78vw, 650px);
    display: grid;
    place-items: center;
  }

  .taiji-mark {
    position: relative;
    width: min(90vw, 520px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 25%, #111 0 12.5%, transparent 12.8%),
      radial-gradient(circle at 50% 75%, #f7f3eb 0 12.5%, transparent 12.8%),
      radial-gradient(circle at 50% 25%, #f7f3eb 0 25%, transparent 25.3%),
      radial-gradient(circle at 50% 75%, #111 0 25%, transparent 25.3%),
      linear-gradient(90deg, #111 0 50%, #f7f3eb 50% 100%);
    box-shadow: 0 50px 120px rgba(0,0,0,.24), inset 0 0 0 1px rgba(255,255,255,.4);
  }

  .taiji-mark::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 20%, rgba(255,255,255,.45), transparent 26%), radial-gradient(circle at 68% 84%, rgba(0,0,0,.28), transparent 30%);
    pointer-events: none;
  }

  .dot { display: none; }

  .orbit-label {
    position: absolute;
    max-width: 220px;
    padding: 1.05rem 1.18rem;
    border-radius: 999px;
    box-shadow: 0 22px 70px rgba(0,0,0,.16);
    font-size: .96rem;
  }

  .orbit-label span {
    display: block;
    opacity: .7;
  }

  .orbit-label strong {
    display: block;
    margin-top: .2rem;
  }

  .orbit-online {
    top: 7%;
    right: 2%;
    background: #fff;
    color: #111;
  }

  .orbit-drm {
    left: 0;
    bottom: 10%;
    background: #111;
    color: #fff;
  }

  .dual-section,
  .featured-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-intro {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .section-intro.center {
    margin-inline: auto;
    text-align: center;
  }

  .section-intro h2 {
    font-size: clamp(2.2rem, 5vw, 4.8rem);
    line-height: .95;
  }

  .decision-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .decision-card {
    min-height: 380px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1.5rem, 4vw, 3rem);
    border-radius: 40px;
  }

  .decision-card.light {
    background: #fffaf0;
    color: #111;
    box-shadow: inset 0 0 0 1px rgba(17,17,17,.09);
  }

  .decision-card.dark {
    background: #090909;
    color: #fff;
  }

  .decision-card.dark p { color: rgba(255,255,255,.72); }
  .decision-card h3 {
    max-width: 640px;
    margin: 0;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: .96;
    letter-spacing: -.05em;
  }

  .card-side {
    margin: 0 0 auto;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: .12em;
    font-size: .76rem;
  }

  .decision-card a {
    width: fit-content;
    margin-top: 1rem;
    color: currentColor;
    font-weight: 850;
    text-decoration-thickness: 1px;
    text-underline-offset: 5px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .featured-card {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    padding: 1.35rem;
    border-radius: 28px;
    color: #111;
    background: rgba(255,255,255,.72);
    text-decoration: none;
    box-shadow: inset 0 0 0 1px rgba(17,17,17,.08);
  }

  .featured-card:hover,
  .theme-links a:hover {
    transform: translateY(-3px);
  }

  .featured-card span {
    color: #8a7759;
    font-weight: 900;
  }

  .featured-card h3 {
    margin: auto 0 .75rem;
    font-size: 1.35rem;
    line-height: 1.1;
    letter-spacing: -.03em;
  }

  .featured-card p {
    margin: 0;
    color: rgba(17,17,17,.62);
    line-height: 1.55;
  }

  .guide-map {
    padding: clamp(4rem, 8vw, 7rem) 0 6rem;
    color: #fff;
  }

  .section-intro.inverted p,
  .section-intro.inverted .eyebrow { color: rgba(255,255,255,.68); }
  .section-intro.inverted h2 { color: #fff; }

  .theme-stack {
    display: grid;
    gap: 1rem;
  }

  .theme-panel {
    display: grid;
    grid-template-columns: minmax(260px, .38fr) minmax(0, .62fr);
    gap: 1.2rem;
    padding: clamp(1rem, 3vw, 1.5rem);
    border-radius: 36px;
    background: linear-gradient(135deg, rgba(255,255,255,.12), rgba(255,255,255,.045));
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.11);
  }

  .theme-heading {
    position: sticky;
    top: 1rem;
    align-self: start;
    padding: 1rem;
  }

  .theme-heading h3 {
    margin: 0;
    font-size: clamp(1.65rem, 3vw, 2.8rem);
    line-height: 1;
    letter-spacing: -.04em;
  }

  .theme-heading p { color: rgba(255,255,255,.66); }
  .theme-heading strong {
    display: inline-flex;
    padding: .5rem .8rem;
    border-radius: 999px;
    background: #fff;
    color: #111;
  }

  .theme-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .7rem;
  }

  .theme-links a {
    display: grid;
    gap: .35rem;
    min-height: 132px;
    padding: 1rem;
    border-radius: 22px;
    background: #f7f3eb;
    color: #111;
    text-decoration: none;
    transition: transform 160ms ease, background 160ms ease;
  }

  .theme-links span {
    color: #846f4d;
    font-size: .72rem;
    font-weight: 900;
    letter-spacing: .16em;
  }

  .theme-links strong {
    font-size: 1rem;
    line-height: 1.18;
  }

  .theme-links small {
    color: rgba(17,17,17,.58);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 900px) {
    .hero-shell,
    .decision-grid,
    .theme-panel {
      grid-template-columns: 1fr;
    }

    .taiji-orbit {
      min-height: auto;
      padding: 2rem 0 4rem;
    }

    .taiji-mark {
      width: min(82vw, 430px);
    }

    .featured-grid,
    .theme-links {
      grid-template-columns: 1fr;
    }

    .theme-heading {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .taiji-hero,
    .dual-section,
    .featured-section,
    .guide-map {
      width: min(100% - 1rem, 1180px);
    }

    .hero-copy h1 {
      font-size: clamp(2.8rem, 18vw, 4.5rem);
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

    .orbit-label {
      position: static;
      margin-top: .75rem;
    }

    .taiji-orbit {
      display: flex;
      flex-direction: column;
    }

    .decision-card {
      min-height: 320px;
      border-radius: 30px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      scroll-behavior: auto !important;
      transition: none !important;
    }
  }
</style>
