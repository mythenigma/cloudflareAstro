---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const pageTitle = 'MaiPDF Secure Sharing Guides';
const pageDescription = 'Practical guides for secure PDF sharing, App DRM, screenshot protection, .maipdf files, watermarks, QR codes, access limits, and Maiimg image sharing.';

function getDisplayDate(data: { pubDate: Date; updatedDate?: Date }) {
  const publishedAt = data.pubDate instanceof Date ? data.pubDate : new Date(data.pubDate);
  const updatedAt = data.updatedDate
    ? data.updatedDate instanceof Date
      ? data.updatedDate
      : new Date(data.updatedDate)
    : null;
  return updatedAt && updatedAt.getTime() > publishedAt.getTime() ? updatedAt : publishedAt;
}

const allPosts = (await getCollection('blog'))
  .filter((post) => post.data.noindex !== true)
  .sort((a, b) => getDisplayDate(b.data).valueOf() - getDisplayDate(a.data).valueOf());

const featuredSlugs = [
  'en/free-pdf-screenshot-protection-software',
  'en/online-pdf-sharing-vs-app-drm',
  'en/secure-pdf-reader-with-screenshot-protection',
  'en/what-is-a-maipdf-file',
  'en/pdf-device-binding-explained',
  'en/how-to-revoke-access-to-a-pdf-after-sending',
];

const featuredPosts = featuredSlugs
  .map((slug) => allPosts.find((post) => post.id.replace(/\.md$/, '') === slug))
  .filter(Boolean)
  .slice(0, 6);

const latestPosts = allPosts.slice(0, 6);

const onlineFeatures = [
  { title: 'Instant Share', desc: 'Link or QR in seconds' },
  { title: 'No Installation', desc: 'Open in any browser' },
  { title: 'Easy Access', desc: 'Readers need no account' },
  { title: 'Flexible Control', desc: 'Expiry, views, watermarks' },
];

const drmFeatures = [
  { title: 'Anti-Screenshot', desc: 'App-aware protection' },
  { title: 'No Download', desc: 'Protected .maipdf files' },
  { title: 'Device Binding', desc: 'Limit where it opens' },
  { title: 'Audit & Track', desc: 'Revoke and review access' },
];

const moreFeatures = [
  { title: 'Replace PDF', desc: 'Swap the file behind a live link' },
  { title: 'Access Refresh', desc: 'Update rules after sending' },
  { title: 'Watermark & Tracking', desc: 'Trace leaks with dynamic marks' },
  { title: 'Cross-Platform', desc: 'Works across devices and apps' },
  { title: 'Enterprise Ready', desc: 'Built for teams and workflows' },
];

const topics = [
  {
    title: 'Online PDF Sharing',
    desc: 'Create secure PDF links and QR codes, set expiry, and track opens without asking readers to install anything.',
    href: '/blog/en/share-pdf-online',
    label: 'Fast browser sharing',
  },
  {
    title: 'App DRM & .maipdf',
    desc: 'Learn when protected .maipdf files and the MaiPDF App are better than ordinary browser links.',
    href: '/blog/en/online-pdf-sharing-vs-app-drm',
    label: 'Stronger control',
  },
  {
    title: 'Screenshot Protection',
    desc: 'Understand why browsers cannot fully block screenshots and how app-based reading changes the risk model.',
    href: '/blog/en/secure-pdf-reader-with-screenshot-protection',
    label: 'New App capability',
  },
  {
    title: 'View Limits & Expiry',
    desc: 'Control how many times a PDF can be opened, when access ends, and how to revoke links later.',
    href: '/blog/en/limit-pdf-views-drm',
    label: 'Access rules',
  },
  {
    title: 'Watermark & Tracking',
    desc: 'Use dynamic watermarks and activity logs to identify leaks and make document forwarding riskier.',
    href: '/blog/en/dynamic-watermarks-on-pdf',
    label: 'Trace leaks',
  },
  {
    title: 'Maiimg Image Sharing',
    desc: 'Guides for secure image galleries, QR-code image delivery, portfolio links, and client review workflows.',
    href: '/blog/en/maiimg-secure-image-sharing-access-control',
    label: 'Image workflows',
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="ink-home">
    <section class="hero" aria-label="MaiPDF two ways to share">
      <div class="hero-atmosphere" aria-hidden="true">
        <div class="mist mist-a"></div>
        <div class="mist mist-b"></div>
        <div class="sun-glow"></div>
        <svg class="mountain-line" viewBox="0 0 1440 220" preserveAspectRatio="none">
          <path d="M0 180 C120 140 180 120 280 150 C360 175 420 90 520 110 C640 135 700 60 820 95 C940 130 1000 70 1120 100 C1240 130 1320 90 1440 120 L1440 220 L0 220 Z" fill="currentColor" opacity="0.12"/>
          <path d="M0 200 C160 170 240 150 360 175 C480 200 560 130 700 155 C840 180 920 120 1060 150 C1200 180 1300 140 1440 165 L1440 220 L0 220 Z" fill="currentColor" opacity="0.18"/>
        </svg>
      </div>

      <div class="hero-inner">
        <p class="brand-mark">MaiPDF</p>
        <div class="taiji-stage">
          <img
            class="taiji-visual"
            src="/maipdf2026/concepts/en/hero-taiji-ink-hires.png"
            alt="MaiPDF yin-yang visual: Online Sharing on the light side, App DRM on the dark side"
            width="1254"
            height="1254"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
        <h1>
          One PDF. <em>Two Ways</em> to Share.<br />Total Control.
        </h1>
        <p class="hero-lead">
          Share freely. Protect deeply. Convenience and security in balance.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href="https://maipdf.com">Try Online Sharing</a>
          <a class="btn ghost" href="https://drm.maipdf.com">Explore App DRM</a>
        </div>
      </div>
    </section>

    <div class="ink-divider" aria-hidden="true">
      <span></span>
      <svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.2L12 16.8 5.7 21l2.3-7.2-6-4.4h7.6z"/></svg>
      <span></span>
    </div>

    <section class="paths" aria-label="Online Sharing and App DRM">
      <div class="paths-shell">
        <a class="path-panel online" href="https://maipdf.com">
          <p class="path-kicker">Path One</p>
          <h2>Online Sharing</h2>
          <p class="path-desc">Fast browser links and QR codes when speed and reach matter most.</p>
          <ul>
            {onlineFeatures.map((item) => (
              <li>
                <strong>{item.title}</strong>
                <span>{item.desc}</span>
              </li>
            ))}
          </ul>
          <span class="path-cta">Open MaiPDF online →</span>
        </a>

        <div class="path-hub" aria-hidden="true">
          <span>PDF</span>
        </div>

        <a class="path-panel drm" href="https://drm.maipdf.com">
          <p class="path-kicker">Path Two</p>
          <h2>App DRM</h2>
          <p class="path-desc">Protected <code>.maipdf</code> files when screenshots, devices, and revocation matter.</p>
          <ul>
            {drmFeatures.map((item) => (
              <li>
                <strong>{item.title}</strong>
                <span>{item.desc}</span>
              </li>
            ))}
          </ul>
          <span class="path-cta">Learn about the App →</span>
        </a>
      </div>
    </section>

    <section class="more-features" aria-label="More MaiPDF features">
      <h2>More powerful features</h2>
      <div class="feature-row">
        {moreFeatures.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="learning" aria-label="Learning center">
      <div class="section-heading">
        <p class="eyebrow">Learning Center</p>
        <h2>Guides for the risk you need to solve</h2>
      </div>
      <div class="topic-grid">
        {topics.map((topic) => (
          <a class="topic-link" href={topic.href}>
            <span>{topic.label}</span>
            <h3>{topic.title}</h3>
            <p>{topic.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="articles" aria-label="Recommended guides">
      <div class="section-heading with-link">
        <div>
          <p class="eyebrow">Recommended</p>
          <h2>Start with the core workflows</h2>
        </div>
        <a href="/blog">View all articles →</a>
      </div>
      <div class="article-grid">
        {(featuredPosts.length > 0 ? featuredPosts : latestPosts).map((post) => (
          <a class="article-link" href={`/blog/${post.id.replace(/\.md$/, '')}`}>
            <p class="article-lang">{post.id.split('/')[0].toUpperCase()}</p>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="latest" aria-label="Latest articles">
      <div class="section-heading with-link">
        <div>
          <p class="eyebrow">Latest</p>
          <h2>Fresh tutorials and practical guides</h2>
        </div>
        <a href="/blog">Browse the library →</a>
      </div>
      <div class="latest-list">
        {latestPosts.map((post) => (
          <a href={`/blog/${post.id.replace(/\.md$/, '')}`}>
            <span>{post.id.split('/')[0].toUpperCase()}</span>
            <strong>{post.data.title}</strong>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="closing" aria-label="MaiPDF closing statement">
      <p>MaiPDF — Empowering you to share and protect what matters.</p>
    </section>
  </div>
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Outfit:wght@300;400;500;600;700&display=swap');

  .ink-home {
    --ink: #141414;
    --ink-soft: #3a3a3a;
    --paper: #f3efe6;
    --paper-deep: #e8e2d6;
    --gold: #b08d57;
    --gold-deep: #8c6a3a;
    --mist: rgba(243, 239, 230, 0.72);
    --drm: #161616;
    --line: rgba(20, 20, 20, 0.12);
    --display: "Cormorant Garamond", "Times New Roman", serif;
    --sans: "Outfit", "Avenir Next", "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(176, 141, 87, 0.14), transparent 55%),
      linear-gradient(180deg, #f6f2ea 0%, var(--paper) 28%, #efe9de 100%);
    font-family: var(--sans);
    overflow-x: clip;
  }

  .ink-home :global(h1),
  .ink-home :global(h2),
  .ink-home :global(h3),
  .brand-mark {
    font-family: var(--display);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  /* —— Hero —— */
  .hero {
    position: relative;
    min-height: min(100vh, 920px);
    display: grid;
    place-items: center;
    padding: clamp(2.5rem, 6vw, 5rem) 1.25rem 3.5rem;
    isolation: isolate;
  }

  .hero-atmosphere {
    position: absolute;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .mist {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    animation: drift 18s ease-in-out infinite;
  }

  .mist-a {
    width: 55vw;
    height: 35vw;
    top: 8%;
    left: -8%;
    background: rgba(255, 255, 255, 0.55);
  }

  .mist-b {
    width: 45vw;
    height: 30vw;
    top: 18%;
    right: -10%;
    background: rgba(20, 20, 20, 0.06);
    animation-delay: -7s;
  }

  .sun-glow {
    position: absolute;
    top: 6%;
    left: 10%;
    width: min(28vw, 280px);
    height: min(28vw, 280px);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212, 175, 100, 0.35) 0%, rgba(212, 175, 100, 0.08) 45%, transparent 70%);
    animation: pulse-glow 8s ease-in-out infinite;
  }

  .mountain-line {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: clamp(120px, 18vw, 220px);
    color: #1a1a1a;
  }

  .hero-inner {
    width: min(920px, 100%);
    text-align: center;
    display: grid;
    justify-items: center;
    gap: 1.1rem;
  }

  .brand-mark {
    margin: 0;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 0.95;
    color: var(--ink);
    animation: rise-in 0.9s ease both;
  }

  .taiji-stage {
    width: min(420px, 78vw);
    aspect-ratio: 1;
    margin: 0.35rem 0 0.5rem;
    animation: rise-in 1.05s ease 0.08s both, float-soft 7s ease-in-out 1.2s infinite;
  }

  .taiji-visual {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 50%;
    box-shadow:
      0 0 0 1px rgba(20, 20, 20, 0.08),
      0 28px 80px rgba(20, 20, 20, 0.18);
  }

  .hero h1 {
    margin: 0;
    max-width: 16ch;
    font-size: clamp(2rem, 5.2vw, 3.55rem);
    line-height: 1.08;
    color: var(--ink);
    animation: rise-in 1.1s ease 0.16s both;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--gold-deep);
    font-weight: 600;
  }

  .hero-lead {
    margin: 0;
    max-width: 38ch;
    color: var(--ink-soft);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 400;
    line-height: 1.55;
    animation: rise-in 1.15s ease 0.24s both;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 0.6rem;
    animation: rise-in 1.2s ease 0.32s both;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.35rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn.primary {
    color: #f7f4ee;
    background: var(--ink);
    box-shadow: 0 16px 36px rgba(20, 20, 20, 0.22);
  }

  .btn.primary:hover {
    background: #000;
  }

  .btn.ghost {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid rgba(20, 20, 20, 0.18);
    backdrop-filter: blur(8px);
  }

  .btn.ghost:hover {
    background: #fff;
  }

  /* —— Divider —— */
  .ink-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    color: var(--gold);
    padding: 0.5rem 1.25rem 0;
  }

  .ink-divider span {
    width: min(160px, 28vw);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  /* —— Dual paths —— */
  .paths {
    width: min(1100px, calc(100% - 2rem));
    margin: 2.75rem auto 0;
  }

  .paths-shell {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: 0 24px 70px rgba(20, 20, 20, 0.1);
  }

  .path-panel {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    padding: clamp(1.5rem, 3.5vw, 2.4rem);
    text-decoration: none;
    color: inherit;
    min-height: 100%;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .path-panel:hover {
    transform: translateY(-2px);
  }

  .path-panel.online {
    background:
      linear-gradient(160deg, #ffffff 0%, #f7f4ee 100%);
    color: var(--ink);
  }

  .path-panel.drm {
    background:
      radial-gradient(circle at 80% 20%, rgba(176, 141, 87, 0.18), transparent 40%),
      linear-gradient(160deg, #1c1c1c 0%, #0f0f0f 100%);
    color: #f3efe6;
  }

  .path-kicker {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-deep);
  }

  .path-panel.drm .path-kicker {
    color: #d4b483;
  }

  .path-panel h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1;
  }

  .path-desc {
    margin: 0;
    max-width: 34ch;
    line-height: 1.55;
    color: var(--ink-soft);
    font-size: 0.98rem;
  }

  .path-panel.drm .path-desc {
    color: rgba(243, 239, 230, 0.78);
  }

  .path-panel code {
    font-size: 0.9em;
  }

  .path-panel ul {
    list-style: none;
    margin: 0.4rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .path-panel li {
    display: grid;
    gap: 0.15rem;
    padding: 0.7rem 0.75rem;
    border-radius: 14px;
    background: rgba(20, 20, 20, 0.04);
  }

  .path-panel.drm li {
    background: rgba(255, 255, 255, 0.06);
  }

  .path-panel li strong {
    font-size: 0.92rem;
  }

  .path-panel li span {
    font-size: 0.8rem;
    color: var(--ink-soft);
  }

  .path-panel.drm li span {
    color: rgba(243, 239, 230, 0.65);
  }

  .path-cta {
    margin-top: 0.5rem;
    font-weight: 600;
    color: var(--gold-deep);
  }

  .path-panel.drm .path-cta {
    color: #d4b483;
  }

  .path-hub {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 58px;
    height: 58px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: #fff;
    border: 1px solid rgba(20, 20, 20, 0.12);
    box-shadow: 0 10px 30px rgba(20, 20, 20, 0.18);
    z-index: 2;
    font-family: var(--display);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--ink);
  }

  /* —— More features —— */
  .more-features {
    width: min(1100px, calc(100% - 2rem));
    margin: 3.5rem auto 0;
    text-align: center;
  }

  .more-features > h2 {
    margin: 0 0 1.5rem;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .feature-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .feature-row article {
    padding: 1rem 0.5rem;
  }

  .feature-row h3 {
    margin: 0 0 0.35rem;
    font-size: 1.15rem;
  }

  .feature-row p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.88rem;
    line-height: 1.45;
  }

  /* —— Learning / articles —— */
  .learning,
  .articles,
  .latest {
    width: min(1100px, calc(100% - 2rem));
    margin: 3.75rem auto 0;
  }

  .section-heading {
    max-width: 720px;
    margin-bottom: 1.35rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    line-height: 1.08;
  }

  .eyebrow {
    margin: 0 0 0.55rem;
    color: var(--gold-deep);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .section-heading.with-link {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    max-width: none;
  }

  .section-heading.with-link > a {
    flex: 0 0 auto;
    color: var(--gold-deep);
    font-weight: 600;
    text-decoration: none;
  }

  .topic-grid,
  .article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .topic-link,
  .article-link,
  .latest-list a {
    display: block;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    border-top: 1px solid var(--line);
    background: transparent;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .topic-link:hover,
  .article-link:hover,
  .latest-list a:hover {
    background: rgba(255, 255, 255, 0.45);
    border-color: rgba(176, 141, 87, 0.45);
  }

  .topic-link span,
  .article-lang,
  .latest-list span {
    display: inline-flex;
    margin: 0 0 0.65rem;
    color: var(--gold-deep);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .topic-link h3,
  .article-link h3 {
    margin: 0 0 0.55rem;
    font-size: 1.25rem;
    line-height: 1.15;
  }

  .topic-link p,
  .article-link p,
  .latest-list p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .latest-list {
    display: grid;
    gap: 0;
  }

  .latest-list a {
    display: grid;
    grid-template-columns: 54px minmax(0, 0.9fr) minmax(0, 1.25fr);
    gap: 1rem;
    align-items: start;
  }

  .latest-list strong {
    font-family: var(--display);
    font-size: 1.15rem;
    line-height: 1.25;
    font-weight: 600;
  }

  .closing {
    margin-top: 4rem;
    padding: 3.5rem 1.25rem 4.5rem;
    text-align: center;
    background:
      linear-gradient(180deg, transparent 0%, rgba(20, 20, 20, 0.92) 28%, #0d0d0d 100%);
    color: #f3efe6;
  }

  .closing p {
    margin: 0 auto;
    max-width: 28ch;
    font-family: var(--display);
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    line-height: 1.25;
    font-weight: 500;
  }

  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float-soft {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes drift {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(3%, 2%); }
