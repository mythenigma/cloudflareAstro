---
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

function getDisplayDate(data: { pubDate: Date; updatedDate?: Date }) {
  const publishedAt = data.pubDate instanceof Date ? data.pubDate : new Date(data.pubDate);
  const updatedAt = data.updatedDate
    ? data.updatedDate instanceof Date
      ? data.updatedDate
      : new Date(data.updatedDate)
    : null;
  return updatedAt && updatedAt.getTime() > publishedAt.getTime() ? updatedAt : publishedAt;
}

const posts = (await getCollection('blog'))
  .filter((post) => post.data.noindex !== true)
  .sort((a, b) => getDisplayDate(b.data).valueOf() - getDisplayDate(a.data).valueOf());

const normalizeId = (id: string) => id.replace(/\.md$/, '');
const postHref = (id: string) => `/blog/${normalizeId(id)}`;
const textFor = (post: (typeof posts)[number]) => `${post.id} ${post.data.title} ${post.data.description ?? ''} ${(post.data.tags ?? []).join(' ')}`.toLowerCase();

const languageSections = [
  { key: 'en', label: 'English', posts: posts.filter((post) => post.id.startsWith('en/')) },
  { key: 'cn', label: 'Chinese', posts: posts.filter((post) => post.id.startsWith('cn/')) },
  { key: 'es', label: 'Spanish', posts: posts.filter((post) => post.id.startsWith('es/')) },
];

const topicDefs = [
  {
    name: 'Anti-Screenshot & App DRM',
    desc: 'Use the MaiPDF App, .maipdf files, device binding, and screen-capture controls when browser sharing is not enough.',
    keywords: ['screenshot', 'screen-capture', 'screen capture', 'drm', 'maipdf file', '.maipdf', 'device binding', 'protected reader'],
  },
  {
    name: 'Online PDF Sharing',
    desc: 'Turn PDFs into controlled links and QR codes for fast browser-based delivery.',
    keywords: ['share pdf', 'pdf sharing', 'pdf link', 'upload-pdf', 'online', 'browser', 'link generation'],
  },
  {
    name: 'View Limits & Expiry',
    desc: 'Limit opens, set expiration, revoke links, and manage controlled access after sharing.',
    keywords: ['view limit', 'limits', 'expiry', 'expiration', 'revoke', 'access control', 'opens'],
  },
  {
    name: 'Watermark & Tracking',
    desc: 'Trace leaks with dynamic watermarks, activity logs, read alerts, and viewer information.',
    keywords: ['watermark', 'tracking', 'analytics', 'trace', 'logs', 'read alert'],
  },
  {
    name: 'QR Codes & Mobile Reading',
    desc: 'Share PDFs by QR code for classrooms, events, health reports, and mobile-first workflows.',
    keywords: ['qr', 'qrcode', 'qr code', 'mobile', 'wechat', 'whatsapp'],
  },
  {
    name: 'Maiimg Image Sharing',
    desc: 'Secure image hosting, gallery sharing, portfolio links, QR image delivery, and client review workflows.',
    keywords: ['maiimg', 'image', 'gallery', 'portfolio', 'photo'],
  },
];

const topicSections = topicDefs.map((topic) => ({
  ...topic,
  posts: posts.filter((post) => topic.keywords.some((kw) => textFor(post).includes(kw))).slice(0, 6),
}));

const featuredSlugs = [
  'en/free-pdf-screenshot-protection-software',
  'en/secure-pdf-reader-with-screenshot-protection',
  'en/online-pdf-sharing-vs-app-drm',
  'en/pdf-drm-for-online-courses',
  'en/protect-confidential-pdfs-before-sending',
  'en/sell-pdf-workbooks-without-losing-control',
];

const featuredPosts = featuredSlugs
  .map((slug) => posts.find((post) => normalizeId(post.id) === slug))
  .filter(Boolean);

const latestPosts = posts.slice(0, 10);
---

<Layout title={`Blog | ${SITE_TITLE}`} description="MaiPDF tutorials for secure PDF sharing, App DRM, screenshot protection, view limits, watermarks, QR codes, and Maiimg image sharing.">
  <main class="blog-home">
    <section class="blog-hero">
      <p class="eyebrow">MaiPDF Learning Center</p>
      <h1>Guides for secure PDF sharing, App DRM, and screenshot-aware document workflows</h1>
      <p>
        Browse practical MaiPDF and Maiimg tutorials by problem: online PDF links, protected .maipdf files,
        screenshot protection, device binding, watermarks, QR codes, view limits, and access tracking.
      </p>
      <div class="hero-links">
        <a href="#topics">Browse topics</a>
        <a href="#latest">Latest articles</a>
        <a href="https://drm.maipdf.com">App DRM site</a>
      </div>
    </section>

    <section class="stat-row" aria-label="Content library stats">
      {languageSections.map((section) => (
        <a href={`#${section.key}`}>
          <strong>{section.posts.length}</strong>
          <span>{section.label} articles</span>
        </a>
      ))}
    </section>

    <section class="section-block" id="topics">
      <div class="section-heading">
        <p class="eyebrow">Browse by problem</p>
        <h2>Choose the security question your reader is asking</h2>
      </div>
      <div class="topic-grid">
        {topicSections.map((topic) => (
          <section class="topic-card">
            <div class="topic-card-head">
              <h3>{topic.name}</h3>
              <span>{topic.posts.length} guides</span>
            </div>
            <p>{topic.desc}</p>
            <div class="mini-list">
              {topic.posts.slice(0, 3).map((post) => (
                <a href={postHref(post.id)}>{post.data.title}</a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="section-block featured-block">
      <div class="section-heading">
        <p class="eyebrow">Recommended first reads</p>
        <h2>Core articles that explain the new product story</h2>
      </div>
      <div class="featured-grid">
        {featuredPosts.map((post) => (
          <a class="featured-card" href={postHref(post.id)}>
            <span>{post.id.split('/')[0].toUpperCase()}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section-block" id="latest">
      <div class="section-heading split-heading">
        <div>
          <p class="eyebrow">Latest updates</p>
          <h2>Newest articles across the library</h2>
        </div>
      </div>
      <div class="latest-list">
        {latestPosts.map((post) => (
          <a href={postHref(post.id)}>
            <span>{post.id.split('/')[0].toUpperCase()}</span>
            <strong>{post.data.title}</strong>
            <small><FormattedDate date={getDisplayDate(post.data)} /></small>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section-block library-block">
      <div class="section-heading">
        <p class="eyebrow">Full library</p>
        <h2>Browse by language</h2>
      </div>
      <div class="language-tabs" id="langFilter">
        <button class="active" data-lang="all">All languages <span>{posts.length}</span></button>
        {languageSections.map((section) => (
          <button data-lang={section.label}>{section.label} <span>{section.posts.length}</span></button>
        ))}
      </div>

      <div class="language-grid" id="sectionsGrid">
        {languageSections.map((section) => (
          <section class="language-column visible" id={section.key} data-section={section.label}>
            <div class="language-header">
              <h3>{section.label}</h3>
              <span>{section.posts.length} articles</span>
            </div>
            <div class="post-list">
              {section.posts.map((post) => (
                <a href={postHref(post.id)}>
                  <strong>{post.data.title}</strong>
                  <small><FormattedDate date={getDisplayDate(post.data)} /></small>
                  <p>{post.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filter = document.getElementById('langFilter');
      const grid = document.getElementById('sectionsGrid');
      if (!filter || !grid) return;
      const buttons = filter.querySelectorAll<HTMLButtonElement>('button');
      const boxes = grid.querySelectorAll<HTMLElement>('.language-column');

      function update(selected: string) {
        buttons.forEach((button) => button.classList.toggle('active', button.dataset.lang === selected));
        boxes.forEach((box) => box.classList.toggle('visible', selected === 'all' || box.dataset.section === selected));
        try { localStorage.setItem('blog-lang', selected); } catch {}
      }

      buttons.forEach((button) => button.addEventListener('click', () => update(button.dataset.lang || 'all')));
      let saved = 'all';
      try { saved = localStorage.getItem('blog-lang') || 'all'; } catch {}
      if (![...buttons].some((button) => button.dataset.lang === saved)) saved = 'all';
      update(saved);
    });
  </script>
</Layout>

<style>
  .blog-home {
    width: min(1180px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 3rem 0 5rem;
    color: #0f172a;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #2563eb;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .blog-hero {
    border: 1px solid #dbeafe;
    border-radius: 30px;
    padding: clamp(2rem, 5vw, 4rem);
    background: radial-gradient(circle at 12% 0%, rgba(37, 99, 235, 0.18), transparent 30%), linear-gradient(135deg, #eff6ff, #f8fafc 55%, #eef2ff);
  }

  .blog-hero h1 {
    max-width: 980px;
    margin: 0;
    color: #0f172a;
    font-size: clamp(2.2rem, 4.6vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .blog-hero p:not(.eyebrow) {
    max-width: 820px;
    margin: 1.4rem 0 0;
    color: #334155;
    font-size: 1.18rem;
    line-height: 1.65;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }

  .hero-links a,
  .language-tabs button {
    border: 1px solid #bfdbfe;
    border-radius: 999px;
    background: #fff;
    color: #1d4ed8;
    font-weight: 850;
    text-decoration: none;
  }

  .hero-links a {
    padding: 0.72rem 1rem;
  }

  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin: 1rem 0 3.5rem;
  }

  .stat-row a,
  .topic-card,
  .featured-card,
  .latest-list a,
  .language-column {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 22px;
    box-shadow: 0 18px 55px rgba(15, 23, 42, 0.06);
  }

  .stat-row a {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    padding: 1rem 1.25rem;
    color: #0f172a;
    text-decoration: none;
  }

  .stat-row strong {
    color: #2563eb;
    font-size: 2rem;
    line-height: 1;
  }

  .section-block {
    margin-top: 4rem;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 1.35rem;
  }

  .section-heading h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.75rem, 3vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .topic-grid,
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .topic-card,
  .featured-card {
    padding: 1.45rem;
    color: inherit;
    text-decoration: none;
  }

  .topic-card-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
  }

  .topic-card h3,
  .featured-card h3 {
    margin: 0 0 0.7rem;
    color: #0f172a;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .topic-card-head span,
  .featured-card span,
  .latest-list span {
    color: #2563eb;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .topic-card p,
  .featured-card p,
  .latest-list p,
  .post-list p {
    margin: 0;
    color: #475569;
    line-height: 1.58;
  }

  .mini-list {
    display: grid;
    gap: 0.45rem;
    margin-top: 1rem;
  }

  .mini-list a {
    color: #1d4ed8;
    font-weight: 750;
    text-decoration: none;
  }

  .latest-list {
    display: grid;
    gap: 0.8rem;
  }

  .latest-list a {
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) auto;
    gap: 0.8rem 1rem;
    padding: 1rem 1.2rem;
    color: inherit;
    text-decoration: none;
  }

  .latest-list strong {
    color: #0f172a;
  }

  .latest-list small {
    color: #64748b;
  }

  .latest-list p {
    grid-column: 2 / -1;
  }

  .language-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.2rem;
  }

  .language-tabs button {
    padding: 0.65rem 1rem;
    cursor: pointer;
  }

  .language-tabs button.active {
    color: #fff;
    background: #2563eb;
    border-color: #2563eb;
  }

  .language-tabs span {
    opacity: 0.75;
  }

  .language-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .language-column {
    display: none;
    overflow: hidden;
  }

  .language-column.visible {
    display: block;
  }

  .language-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.1rem;
    color: #fff;
    background: linear-gradient(135deg, #2563eb, #4f46e5);
  }

  .language-header h3 {
    margin: 0;
    color: #fff;
  }

  .post-list {
    max-height: 620px;
    overflow: auto;
  }

  .post-list a {
    display: block;
    padding: 1rem 1.1rem;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid #e2e8f0;
  }

  .post-list strong {
    display: block;
    color: #0f172a;
    line-height: 1.25;
  }

  .post-list small {
    display: block;
    margin: 0.4rem 0;
    color: #64748b;
  }

  @media (max-width: 900px) {
    .blog-home {
      width: min(100% - 1rem, 720px);
      padding-top: 1.2rem;
    }

    .stat-row,
    .topic-grid,
    .featured-grid,
    .language-grid {
      grid-template-columns: 1fr;
    }

    .latest-list a {
      grid-template-columns: 1fr;
    }

    .latest-list p {
      grid-column: auto;
    }
  }

  :global(body.dark-mode) .blog-home {
    color: #e5e7eb;
  }

  :global(body.dark-mode) .blog-hero {
    background: radial-gradient(circle at 12% 0%, rgba(96, 165, 250, 0.22), transparent 30%), linear-gradient(135deg, #0f172a, #111827 55%, #1e1b4b);
    border-color: rgba(148, 163, 184, 0.28);
  }

  :global(body.dark-mode) .blog-hero h1,
  :global(body.dark-mode) .section-heading h2,
  :global(body.dark-mode) .topic-card h3,
  :global(body.dark-mode) .featured-card h3,
  :global(body.dark-mode) .latest-list strong,
  :global(body.dark-mode) .post-list strong,
  :global(body.dark-mode) .stat-row a {
    color: #f8fafc;
  }

  :global(body.dark-mode) .blog-hero p:not(.eyebrow),
  :global(body.dark-mode) .topic-card p,
  :global(body.dark-mode) .featured-card p,
  :global(body.dark-mode) .latest-list p,
  :global(body.dark-mode) .post-list p,
  :global(body.dark-mode) .latest-list small,
  :global(body.dark-mode) .post-list small {
    color: #cbd5e1;
  }

  :global(body.dark-mode) .stat-row a,
  :global(body.dark-mode) .topic-card,
  :global(body.dark-mode) .featured-card,
  :global(body.dark-mode) .latest-list a,
  :global(body.dark-mode) .language-column {
    background: #111827;
    border-color: rgba(148, 163, 184, 0.24);
    box-shadow: 0 18px 55px rgba(0, 0, 0, 0.28);
  }

  :global(body.dark-mode) .language-tabs button,
  :global(body.dark-mode) .hero-links a {
    background: #111827;
    border-color: rgba(148, 163, 184, 0.34);
    color: #bfdbfe;
  }

  :global(body.dark-mode) .language-tabs button.active {
    background: #2563eb;
    border-color: #2563eb;
    color: #fff;
  }

  :global(body.dark-mode) .post-list a {
    border-bottom-color: rgba(148, 163, 184, 0.2);
  }
</style>
